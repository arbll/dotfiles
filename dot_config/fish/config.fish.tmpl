# starship.rs prompt
starship init fish | source

if test -d ~/dd
# Load homebrew shell variables
{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ else -}}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ end -}}

# Force certain more-secure behaviours from homebrew
export HOMEBREW_NO_INSECURE_REDIRECT=1
export HOMEBREW_CASK_OPTS=--require-sha
{{ if eq .chezmoi.os "darwin" -}}
export HOMEBREW_DIR=/opt/homebrew
export HOMEBREW_BIN=/opt/homebrew/bin
{{ else -}}
export HOMEBREW_DIR=/home/linuxbrew/.linuxbrew
export HOMEBREW_BIN=/home/linuxbrew/.linuxbrew/bin
{{ end -}}

# Load python shims
eval "$(pyenv init -)"

# Load ruby shims
eval "$(rbenv init -)"

# Load direnv hook
eval "$(direnv hook fish)"

{{ if eq .chezmoi.os "darwin" -}}
# Prefer GNU binaries to Macintosh binaries.
export PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH"

{{ end -}}
# Add datadog devtools binaries to the PATH
export PATH="$HOME/dd/devtools/bin:$PATH"

# Point GOPATH to our go sources
export GOPATH="$HOME/go"

# Add binaries that are go install-ed to PATH
export PATH="$GOPATH/bin:$PATH"

# Point DATADOG_ROOT to ~/dd symlink
export DATADOG_ROOT="$HOME/dd"

# Tell the devenv vm to mount $GOPATH/src rather than just dd-go
export MOUNT_ALL_GO_SRC=1

# store key in the login keychain instead of aws-vault managing a hidden keychain
export AWS_VAULT_KEYCHAIN_NAME=login

# tweak session times so you don't have to re-enter passwords every 5min
export AWS_SESSION_TTL=24h
export AWS_ASSUME_ROLE_TTL=1h

# Helm switch from storing objects in kubernetes configmaps to
# secrets by default, but we still use the old default.
export HELM_DRIVER=configmap

export GO111MODULE=auto
# Configure Go to pull go.ddbuild.io packages.
export GONOSUMDB=github.com/DataDog,go.ddbuild.io
export GOPRIVATE=
export GOPROXY="https://depot-read-api-go.us1.ddbuild.io/magicmirror/magicmirror/@current/|https://depot-read-api-go.us1.ddbuild.io/magicmirror/magicmirror/@current/|https://depot-read-api-go.us1.ddbuild.io/magicmirror/testing/@current/"

export GITLAB_HOST=gitlab.ddbuild.io

# Load ddtool completions
if test -f (brew --prefix)/share/fish/vendor_completions.d/ddtool.fish
    source (brew --prefix)/share/fish/vendor_completions.d/ddtool.fish
end

{{ if eq .chezmoi.os "darwin" -}}
# Load dd-gitsign SSH key (laptop only, workspaces use SSH agent forwarding)
dd-gitsign load-key | source
{{ end -}}
end
