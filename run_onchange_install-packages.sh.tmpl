{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

if ! command -v brew &>/dev/null; then
  echo "Installing Homebrew..."
  # SSH keys may not be available during workspace creation — temporarily
  # remove any git SSH-rewrite rules so Homebrew can clone over HTTPS
  SSH_REWRITE=$(git config --global --get url."git@github.com:".insteadOf 2>/dev/null || true)
  if [ -n "$SSH_REWRITE" ]; then
    git config --global --unset url."git@github.com:".insteadOf
  fi
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  if [ -n "$SSH_REWRITE" ]; then
    git config --global url."git@github.com:".insteadOf "$SSH_REWRITE"
  fi
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.linux.tap -}}
tap {{ .name | quote }}, {{ .url | quote }}
{{ end -}}
{{ range .packages.linux.brew -}}
brew {{ . | quote }}
{{ end -}}
EOF
{{ else if eq .chezmoi.os "darwin" -}}
#!/bin/bash

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.mac.tap -}}
tap {{ .name | quote }}, {{ .url | quote }}
{{ end -}}
{{ range .packages.mac.brew -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.mac.cask -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ end -}}
