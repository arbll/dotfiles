{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash

if ! command -v brew &>/dev/null; then
  echo "brew not found, skipping package install on linux"
  exit 0
fi

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.linux.brew -}}
brew {{ . | quote }}
{{ end -}}
EOF
{{ else if eq .chezmoi.os "darwin" -}}
#!/bin/bash

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.mac.brew -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.mac.cask -}}
cask {{ . | quote }}
{{ end -}}
EOF
{{ end -}}
